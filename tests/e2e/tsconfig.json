{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "isolatedModules": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false
  },
  "include": ["specs/**/*.ts", "playwright.config.ts"]
}
